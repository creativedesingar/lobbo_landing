  <!-- ============================================================
       Behaviour: fade-up on scroll
       ============================================================ -->
  {% raw %}
  <script>
    (function () {
      var root = document.documentElement;
      root.classList.add('js-ready');
      var reveals = Array.prototype.slice.call(
        document.querySelectorAll('.reveal, .reveal-clip, .title-mask')
      );

      function reveal(el) { el.classList.add('is-visible'); }

      // Reveal only what is actually in the viewport right now.
      function revealInView() {
        var vh = window.innerHeight || document.documentElement.clientHeight;
        for (var i = 0; i < reveals.length; i++) {
          var el = reveals[i];
          if (el.classList.contains('is-visible')) continue;
          var r = el.getBoundingClientRect();
          // require the element to be ~8% into the viewport before firing
          if (r.top < vh * 0.92 && r.bottom > 0) reveal(el);
        }
      }

      // 1. First paint: reveal anything already above the fold.
      revealInView();

      // 2. Primary: IntersectionObserver fires each section as it scrolls in.
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              reveal(entry.target);
              io.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -8% 0px' });
        reveals.forEach(function (el) {
          if (!el.classList.contains('is-visible')) io.observe(el);
        });
      }

      // 3. Universal fallback: also reveal in-view items on scroll/resize.
      //    Cheap, and guarantees the effect even if IO is flaky in some host.
      var ticking = false;
      function onScroll() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(function () { revealInView(); ticking = false; });
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });

      // 4. Hero load sequence — fire on next frame so the entry transitions run.
      var hero = document.querySelector('.hero');
      if (hero) {
        requestAnimationFrame(function () {
          requestAnimationFrame(function () { hero.classList.add('hero-in'); });
        });
      }
    })();
  </script>
  {% endraw %}

  <!-- ============================================================
       Hero parallax — content sinks & fades on scroll-down, returns
       on scroll-up; background drifts slower for depth. Disabled for
       reduced-motion. Scroll-linked, so it reverses naturally.
       ============================================================ -->
  {% raw %}
  <script>
    (function () {
      var hero = document.querySelector('.hero');
      if (!hero) return;
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      var bg    = hero.querySelector('.hero-bg');
      var inner = hero.querySelector('.hero-inner');
      var cue   = hero.querySelector('.hero-scrollcue');
      var ticking = false;

      function update() {
        ticking = false;
        var y  = window.pageYOffset || document.documentElement.scrollTop || 0;
        var vh = window.innerHeight || 1;
        if (y > vh) return;                 // only animate while hero is on screen
        var p = y / vh;                     // 0 at top → 1 one viewport down
        if (bg)    bg.style.transform = 'translate3d(0,' + (y * 0.15) + 'px,0)';
        if (inner) {
          inner.style.transform = 'translateY(' + (y * 0.32) + 'px)';
          inner.style.opacity   = String(Math.max(0, 1 - p * 1.15));
        }
        if (cue)   cue.style.opacity = String(Math.max(0, 0.75 - p * 2.5));
      }

      window.addEventListener('scroll', function () {
        if (!ticking) { ticking = true; requestAnimationFrame(update); }
      }, { passive: true });
      window.addEventListener('resize', function () {
        if (!ticking) { ticking = true; requestAnimationFrame(update); }
      }, { passive: true });
      update();
    })();
  </script>
  {% endraw %}

  {% raw %}
  <script>
    (function () {
      var modal = document.getElementById('video-modal');
      if (!modal) return;
      var slot = document.getElementById('video-modal-slot');
      var triggers = document.querySelectorAll('.video-frame[data-video]');
      var closers = modal.querySelectorAll('[data-video-close]');
      var lastFocus = null;

      function open(id) {
        slot.innerHTML =
          '<iframe src="https://www.youtube.com/embed/' + id +
          '?autoplay=1&rel=0" title="Lobbo Session" ' +
          'allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" ' +
          'allowfullscreen></iframe>';
        modal.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        var first = modal.querySelector('[data-video-close]');
        if (first) first.focus();
      }
      function close() {
        modal.classList.remove('is-open');
        slot.innerHTML = '';
        document.body.style.overflow = '';
        if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
      }
      triggers.forEach(function (btn) {
        btn.addEventListener('click', function () {
          lastFocus = btn;
          open(btn.getAttribute('data-video'));
        });
      });
      closers.forEach(function (btn) { btn.addEventListener('click', close); });
      modal.addEventListener('click', function (e) { if (e.target === modal) close(); });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modal.classList.contains('is-open')) close();
      });
    })();
  </script>
  {% endraw %}

  {% raw %}
  <script>
    (function () {
      var modal = document.getElementById('qr-modal');
      if (!modal) return;
      var openers = document.querySelectorAll('[data-qr-soon]');
      var closers = modal.querySelectorAll('[data-qr-close]');
      var lastFocus = null;

      function open(e) {
        lastFocus = (e && e.currentTarget) || document.activeElement;
        modal.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        // Move focus into the dialog for keyboard / screen-reader users.
        var first = modal.querySelector('[data-qr-close]');
        if (first) first.focus();
      }
      function close() {
        modal.classList.remove('is-open');
        document.body.style.overflow = '';
        // Return focus to the trigger so keyboard context isn't lost.
        if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
      }
      openers.forEach(function (btn) { btn.addEventListener('click', open); });
      closers.forEach(function (btn) { btn.addEventListener('click', close); });
      modal.addEventListener('click', function (e) {
        if (e.target === modal) close();
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modal.classList.contains('is-open')) close();
      });
    })();
  </script>
  {% endraw %}

</body>
